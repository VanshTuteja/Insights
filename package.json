{
  "name": "jobfinder-backend",
  "version": "1.0.0",
  "description": "JobFinder AI Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon server/src/server.ts",
    "build": "npm install && npm install --prefix client && npm run build --prefix client",
    "start": "nodemon server/src/server.ts",
    "clean": "rimraf dist",
    "seed": "ts-node -r tsconfig-paths/register src/seed/seed.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "form-data": "^4.0.5",
    "groq-sdk": "^0.5.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.23.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.10",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^7.0.3",
    "nodemon": "^3.1.14",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.2"
